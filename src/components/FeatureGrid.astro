---
import { availableNowFeatures, roadmapFeatures } from '../data/features';
import NotifyMeForm from './NotifyMeForm';
---

<section class="features" aria-labelledby="features-heading">
	<h2 id="features-heading" class="features__heading">Available now</h2>
	<p class="features__subtext">The open source core you can use today.</p>
	<div class="features__grid">
		{availableNowFeatures.map((feature) => (
			<article class="features__card" id={feature.id}>
				<h3 class="features__title">{feature.title}</h3>
				<p class="features__desc">{feature.description}</p>
			</article>
		))}
	</div>
</section>

<section class="roadmap" aria-labelledby="roadmap-heading">
	<h2 id="roadmap-heading" class="roadmap__heading">Roadmap</h2>
	<p class="roadmap__subtext">In development — notify me when ready.</p>
	<div class="roadmap__grid">
		{roadmapFeatures.map((feature) => (
			<article class="roadmap__card" id={feature.id}>
				<span class="roadmap__badge">{feature.badge}</span>
				<h3 class="roadmap__title">{feature.title}</h3>
				<p class="roadmap__desc">{feature.description}</p>
				<NotifyMeForm featureName={feature.title} client:visible />
			</article>
		))}
	</div>
	<p class="roadmap__trust">
		The core proxy and query engine will always remain open source. Advanced governance features are currently in development.
	</p>
</section>

<style>
	.features {
		padding: 3rem 1.5rem 4rem;
		max-width: 64rem;
		margin: 0 auto;
	}

	.features__heading {
		font-size: 1.5rem;
		font-weight: 700;
		text-align: center;
		margin: 0 0 0.5rem;
		color: var(--color-text);
	}

	.features__subtext {
		text-align: center;
		color: var(--color-muted);
		margin: 0 0 2rem;
		font-size: 1rem;
	}

	.features__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
		gap: 1.25rem;
	}

	.features__card {
		padding: 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		background: #fff;
	}

	.features__title {
		font-size: 1rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
		color: var(--color-text);
	}

	.features__desc {
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--color-muted);
		margin: 0;
	}

	/* Roadmap section */
	.roadmap {
		padding: 3rem 1.5rem 4rem;
		max-width: 64rem;
		margin: 0 auto;
	}

	.roadmap__heading {
		font-size: 1.5rem;
		font-weight: 700;
		text-align: center;
		margin: 0 0 0.5rem;
		color: var(--color-text);
	}

	.roadmap__subtext {
		text-align: center;
		color: var(--color-muted);
		margin: 0 0 2rem;
		font-size: 1rem;
	}

	.roadmap__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
		gap: 1.25rem;
	}

	.roadmap__card {
		padding: 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		background: #fafafa;
		opacity: 0.95;
	}

	.roadmap__badge {
		display: inline-block;
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.25rem 0.5rem;
		background: #e0e7ff;
		color: #3730a3;
		border-radius: 0.25rem;
		margin-bottom: 0.5rem;
	}

	.roadmap__title {
		font-size: 1rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
		color: var(--color-text);
	}

	.roadmap__desc {
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--color-muted);
		margin: 0 0 1rem;
	}

	.roadmap__trust {
		text-align: center;
		font-size: 0.875rem;
		color: var(--color-muted);
		margin: 2rem 0 0;
		max-width: 36rem;
		margin-left: auto;
		margin-right: auto;
	}

	/* Notify form (used inside roadmap cards) */
	:global(.notify-form) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}

	:global(.notify-input) {
		flex: 1;
		min-width: 10rem;
		padding: 0.5rem 0.75rem;
		font-size: 0.875rem;
		border: 1px solid var(--color-border);
		border-radius: 0.375rem;
	}

	:global(.notify-btn) {
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		font-weight: 500;
		background: var(--color-primary);
		color: white;
		border: none;
		border-radius: 0.375rem;
		cursor: pointer;
	}

	:global(.notify-btn:hover) {
		background: var(--color-primary-hover);
	}

	:global(.notify-fallback),
	:global(.notify-success),
	:global(.notify-error) {
		font-size: 0.875rem;
		margin: 0.5rem 0 0;
	}

	:global(.notify-success) {
		color: #059669;
	}

	:global(.notify-error) {
		color: #dc2626;
	}
</style>
