---
const githubUrl =
	import.meta.env.PUBLIC_GITHUB_REPO_URL ?? "https://github.com/sessiondb";
const discordUrl =
	import.meta.env.PUBLIC_DISCORD_URL ?? "https://discord.gg/EE682H6U";
---

<section class="cta" aria-labelledby="cta-heading">
	<h2 id="cta-heading" class="cta__title">We're building a better way.</h2>
	<p class="cta__text">
		SessionDB is built by and for the community. The core proxy and query
		engine will always remain open source. Star us on GitHub to follow our
		progress toward the 1.0 release.
	</p>
	<p class="cta__join">Join the community</p>
	<div class="cta__buttons">
		<a
			href={githubUrl}
			rel="noopener noreferrer"
			target="_blank"
			class="cta__btn cta__btn--primary">GitHub</a
		>
		<a
			href={discordUrl}
			class="cta__btn cta__btn--outline"
			rel="noopener noreferrer">Discord</a
		>
	</div>
</section>

<style>
	.cta {
		padding: 4rem 1.5rem 5rem;
		max-width: 40rem;
		margin: 0 auto;
		text-align: center;
		border-top: 1px solid var(--color-border);
	}

	.cta__title {
		font-size: 1.75rem;
		font-weight: 700;
		margin: 0 0 1rem;
		color: var(--color-text);
	}

	.cta__text {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-muted);
		margin: 0 0 1.5rem;
	}

	.cta__join {
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--color-text);
		margin: 0 0 1rem;
	}

	.cta__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.cta__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.625rem 1.25rem;
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
		border-radius: 0.375rem;
		transition: background-color 0.2s, color 0.2s, border-color 0.2s;
	}

	.cta__btn--primary {
		background: white;
		color: var(--color-bg);
		border: none;
	}

	.cta__btn--primary:hover {
		background: #e4e4e7;
		color: var(--color-bg);
	}

	.cta__btn--outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.cta__btn--outline:hover {
		background: var(--color-bg-elevated);
		border-color: var(--color-muted);
	}
</style>
