---
const githubUrl = 'https://github.com/sessiondb';
---

<header class="header">
	<div class="header__inner">
		<a href="/" class="header__logo" aria-label="SessionDB home">SessionDB</a>
		<nav class="header__nav" aria-label="Main">
			<a href="https://docs.sessiondb.in" rel="noopener noreferrer" target="_blank" class="header__link">Docs</a>
			<a href="#features-heading" class="header__link">Features</a>
			<a href="https://demo.sessiondb.in" rel="noopener noreferrer" target="_blank" class="header__link">Demo</a>
		</nav>
		<div class="header__ctas">
			<a href={githubUrl} rel="noopener noreferrer" target="_blank" class="header__btn header__btn--outline">View on GitHub</a>
			<a href="https://demo.sessiondb.in" rel="noopener noreferrer" target="_blank" class="header__btn header__btn--primary">Try Demo</a>
		</div>
	</div>
</header>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
	}

	.header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		gap: 1.5rem;
	}

	.header__logo {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.header__logo:hover {
		color: var(--color-text);
		opacity: 0.9;
	}

	.header__nav {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.header__link {
		font-size: 0.9375rem;
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.header__link:hover {
		color: var(--color-text);
	}

	.header__ctas {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.header__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		border-radius: 0.375rem;
		transition: background-color 0.2s, color 0.2s, border-color 0.2s;
	}

	.header__btn--outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.header__btn--outline:hover {
		background: var(--color-bg-elevated);
		border-color: var(--color-muted);
	}

	.header__btn--primary {
		background: white;
		color: var(--color-bg);
		border: none;
	}

	.header__btn--primary:hover {
		background: #e4e4e7;
		color: var(--color-bg);
	}

	@media (max-width: 768px) {
		.header__nav {
			display: none;
		}

		.header__ctas {
			gap: 0.5rem;
		}

		.header__btn {
			padding: 0.5rem 0.75rem;
			font-size: 0.8125rem;
		}
	}
</style>
