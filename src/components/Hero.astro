---
import DemoLink from './DemoLink';
const githubUrl = 'https://github.com/sessiondb';
---

<section class="hero">
	<div class="hero__gradient" aria-hidden="true" />
	<div class="hero__content">
		<h1 class="hero__title">
			<span class="hero__title-line">The Open Source</span>
			<span class="hero__title-line">Database Proxy</span>
			<span class="hero__title-line">For Modern Teams</span>
		</h1>
		<p class="hero__subtitle">
			SessionDB gives your team secure, AI-powered access to MySQL and Postgres—without sharing a single password.
		</p>
		<p class="hero__tagline">Open-source, self-hosted, scalable.</p>
		<div class="hero__ctas">
			<a class="hero__cta hero__cta--primary" href={githubUrl} rel="noopener noreferrer" target="_blank">
				View on GitHub
			</a>
			<DemoLink client:load>
				<a class="hero__cta hero__cta--secondary" href="https://demo.sessiondb.in" rel="noopener noreferrer" target="_blank">
					Try the Demo
				</a>
			</DemoLink>
		</div>
	</div>
	<div class="hero__visual">
		<div class="hero__card hero__card--1">
			<img
				src="/images/queryrunner.png"
				alt="SessionDB Query Runner with schema explorer and SQL editor"
				class="hero__card-img"
				width="760"
				height="560"
			/>
		</div>
		<div class="hero__card hero__card--2">
			<img
				src="/images/auditlogs.png"
				alt="SessionDB Audit Logs tracking user activities and query executions"
				class="hero__card-img"
				width="760"
				height="560"
			/>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: 3rem;
		max-width: 112rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 3rem;
		/* min-height: 100vh; */
		overflow-x: hidden;
	}

	.hero__gradient {
		position: absolute;
		top: -30%;
		right: -20%;
		width: 80%;
		height: 120%;
		background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.15) 0%, transparent 60%);
		pointer-events: none;
	}

	.hero__content {
		position: relative;
		z-index: 1;
		text-align: center;
		transform: translateX(30);
	}

	.hero__title {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.03em;
		margin: 0 0 1rem;
		color: var(--color-text);
	}

	.hero__title-line {
		display: block;
	}

	.hero__subtitle {
		font-size: 1.125rem;
		line-height: 1.6;
		color: var(--color-muted);
		margin: 0 auto 0.5rem;
		max-width: 32rem;
	}

	.hero__tagline {
		font-size: 0.9375rem;
		color: var(--color-muted);
		margin: 0 auto 2rem;
	}

	.hero__ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
	}

	.hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.5rem;
		font-size: 1rem;
		font-weight: 500;
		text-decoration: none;
		border-radius: 0.5rem;
		transition: background-color 0.2s, color 0.2s, border-color 0.2s;
	}

	.hero__cta--primary {
		background: white;
		color: var(--color-bg);
		border: none;
	}

	.hero__cta--primary:hover {
		background: #e4e4e7;
		color: var(--color-bg);
	}

	.hero__cta--secondary {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.hero__cta--secondary:hover {
		background: var(--color-bg-elevated);
		border-color: var(--color-muted);
	}

	.hero__visual {
		position: relative;
		height: 85vh;
		min-height: 32rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-left: -1.25rem;
	}

	.hero__card {
		position: absolute;
		border-radius: 0.5rem;
		border: 1px solid var(--color-border);
		background: var(--color-bg-card);
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		overflow: hidden;
	}

	.hero__card-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit:fill;
		object-position: center;
		/* Sharper scaling for screenshots */
		image-rendering: -webkit-optimize-contrast;
		image-rendering: crisp-edges;
	}

	.hero__card--1 {
		width: 48rem;
		height: 32rem;
		transform: translate(-50%, -70%) rotate(-2deg);
		top: 50%;
		left: 50%;
		z-index: 0;
	}

	.hero__card--2 {
		width:44rem;
		height: 28rem;
		transform: translate(-58%, -30%) rotate(2deg);
		top: 50%;
		left: 50%;
		z-index: 1;
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			text-align: center;
			padding: 3rem 1rem 4rem;
			min-height: auto;
		}

		.hero__subtitle,
		.hero__tagline {
			margin-left: auto;
			margin-right: auto;
		}

		.hero__ctas {
			justify-content: center;
		}

		.hero__visual {
			display: none;
		}
	}
</style>
