---
const githubUrl = import.meta.env.PUBLIC_GITHUB_REPO_URL ?? 'https://github.com';
---

<header class="hero">
	<h1 class="hero__title">The Open Source Database Proxy for Modern Teams</h1>
	<p class="hero__subtitle">
		SessionDB gives your team secure, AI-powered access to MySQL and Postgres—without sharing a single password.
	</p>
	<section class="hero__ctas">
		<a class="hero__cta hero__cta--primary" href={githubUrl} rel="noopener noreferrer" target="_blank">
			View on GitHub
		</a>
		<a class="hero__cta hero__cta--secondary" href="https://demo.sessiondb.in" rel="noopener noreferrer" target="_blank">
			Try the Demo
		</a>
	</section>
</header>

<style>
	.hero {
		text-align: center;
		max-width: 42rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 4rem;
	}

	.hero__title {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		line-height: 1.2;
		margin: 0 0 1rem;
		color: var(--color-text);
	}

	.hero__subtitle {
		font-size: 1.125rem;
		line-height: 1.6;
		color: var(--color-muted);
		margin: 0 0 2rem;
	}

	.hero__ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
	}

	.hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.5rem;
		font-size: 1rem;
		font-weight: 500;
		text-decoration: none;
		border-radius: 0.5rem;
		transition: background-color 0.2s, color 0.2s;
	}

	.hero__cta--primary {
		background: var(--color-primary);
		color: white;
		border: none;
	}

	.hero__cta--primary:hover {
		background: var(--color-primary-hover);
		color: white;
	}

	.hero__cta--secondary {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.hero__cta--secondary:hover {
		background: rgba(0, 0, 0, 0.04);
	}

	@media (max-width: 640px) {
		.hero {
			padding: 2rem 1rem 3rem;
		}

		.hero__ctas {
			flex-direction: column;
		}

		.hero__cta {
			width: 100%;
		}
	}
</style>
