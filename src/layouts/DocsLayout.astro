---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import OpenSourceCta from "../components/OpenSourceCta.astro";

const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Layout>
  <Header />

  <div class="docs-bg-glow"></div>
  <div class="docs-container">
    <aside class="docs-sidebar">
      <nav aria-label="Documentation Navigation" class="docs-nav">
        
        <div class="nav-section">
          <h3 class="nav-group">Getting Started</h3>
          <ul class="nav-list">
            <li><a href="/docs/installation" class={`nav-link ${currentPath.includes('/docs/installation') ? 'active' : ''}`}>Installation</a></li>
            <li><a href="/docs/tooling" class={`nav-link ${currentPath.includes('/docs/tooling') ? 'active' : ''}`}>CLI Tooling (scli)</a></li>
            <li><a href="/docs/services" class={`nav-link ${currentPath.includes('/docs/services') ? 'active' : ''}`}>Services Overview</a></li>
          </ul>
        </div>

        <div class="nav-section">
          <h3 class="nav-group">Core Server Concepts</h3>
          <ul class="nav-list">
            <li><a href="/docs/architecture" class={`nav-link ${currentPath.includes('/docs/architecture') ? 'active' : ''}`}>Architecture</a></li>
            <li><a href="/docs/database" class={`nav-link ${currentPath.includes('/docs/database') ? 'active' : ''}`}>Database Connectivity</a></li>
            <li><a href="/docs/deployment" class={`nav-link ${currentPath.includes('/docs/deployment') ? 'active' : ''}`}>Deployment</a></li>
          </ul>
        </div>

        <div class="nav-section">
          <h3 class="nav-group">User Interface (UI)</h3>
          <ul class="nav-list">
            <li><a href="/docs/ui-setup" class={`nav-link ${currentPath.includes('/docs/ui-setup') ? 'active' : ''}`}>Frontend Setup</a></li>
            <li><a href="/docs/api-integration" class={`nav-link ${currentPath.includes('/docs/api-integration') ? 'active' : ''}`}>API Integration</a></li>
          </ul>
        </div>

      </nav>
    </aside>

    <main class="docs-content">
      <article class="docs-prose">
        <slot />
      </article>
      
      <div class="docs-footer-nav">
         <!-- Placeholder for Next/Prev buttons if needed -->
      </div>
    </main>
  </div>

  <OpenSourceCta />
  <Footer />
</Layout>

<style>
  .docs-bg-glow {
    position: absolute;
    top: -10%;
    left: 20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(ellipse at top, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .docs-container {
    display: flex;
    max-width: 90rem;
    margin: 0 auto;
    padding: 0 2rem;
    min-height: calc(100vh - 72px); 
    position: relative;
    z-index: 1;
  }

  .docs-sidebar {
    width: 280px;
    flex-shrink: 0;
    padding: 2.5rem 1.5rem 2.5rem 0;
    position: sticky;
    top: 72px;
    height: calc(100vh - 72px);
    overflow-y: auto;
    border-right: 1px solid rgba(255, 255, 255, 0.04);
    background: transparent;
  }
  
  .docs-sidebar::-webkit-scrollbar {
    width: 4px;
  }
  .docs-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }
  .docs-sidebar::-webkit-scrollbar-thumb {
    background-color: var(--color-border);
    border-radius: 10px;
  }

  .docs-nav {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-group {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.6;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    border-radius: 0.375rem;
    transition: all 0.2s ease;
    margin-left: -0.85rem;
    border-left: 2px solid transparent;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.02);
  }

  .nav-link.active {
    color: var(--color-primary);
    background: rgba(59, 130, 246, 0.05);
    font-weight: 500;
    border-left: 2px solid var(--color-primary);
    box-shadow: inset 1px 0 10px -5px rgba(59, 130, 246, 0.4);
  }

  .docs-content {
    flex-grow: 1;
    padding: 3rem 0 5rem 4rem;
    max-width: 58rem;
    position: relative;
  }

  @media (max-width: 1024px) {
    .docs-content {
      padding-left: 2rem;
    }
  }

  @media (max-width: 768px) {
    .docs-container {
      flex-direction: column;
      padding: 0 1.5rem;
    }

    .docs-sidebar {
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      position: static;
      padding: 1.5rem 0;
      margin-bottom: 1rem;
    }

    .nav-list {
       flex-direction: row;
       flex-wrap: wrap;
       gap: 0.5rem;
    }
    
    .nav-link {
      margin-left: 0;
      background: rgba(255,255,255,0.03);
      border-left: none;
      border-bottom: 2px solid transparent;
    }
    
    .nav-link.active {
      border-left: none;
      border-bottom: 2px solid var(--color-primary);
      box-shadow: inset 0 -5px 10px -5px rgba(59, 130, 246, 0.4);
    }

    .docs-content {
      padding: 1.5rem 0 3rem 0;
    }
  }
</style>

<style is:global>
  /* Premium Futuristic Prose Styles - Scoped to docs-prose to avoid leaking */
  .docs-prose {
    color: #e4e4e7;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .docs-prose h1 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 800;
    margin-top: 0;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    color: #ffffff;
    background: linear-gradient(to right, #fff, #a1a1aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .docs-prose h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    letter-spacing: -0.02em;
    color: #ffffff;
  }

  .docs-prose h3 {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #f4f4f5;
  }

  .docs-prose p {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: #a1a1aa;
    line-height: 1.8;
  }

  .docs-prose a {
    color: var(--color-primary);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .docs-prose a:hover {
    color: var(--color-primary-hover);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-shadow: 0 0 8px rgba(59, 130, 246, 0.4);
  }

  .docs-prose ul, .docs-prose ol {
    margin-top: 0;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: #a1a1aa;
  }

  .docs-prose li {
    margin-bottom: 0.75rem;
  }
  
  .docs-prose li strong {
    color: #e4e4e7;
  }

  .docs-prose pre {
    padding: 1.25rem 1.5rem;
    border-radius: 0.5rem;
    background: #09090b; /* Very dark background for terminal feel */
    border: 1px solid rgba(255,255,255,0.08);
    overflow-x: auto;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    line-height: 1.6;
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
  }

  .docs-prose code {
    background: rgba(255,255,255, 0.06);
    padding: 0.2rem 0.4rem;
    border-radius: 0.375rem;
    font-size: 0.85em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--color-primary); 
    border: 1px solid rgba(255,255,255,0.03);
  }

  .docs-prose pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    border: none;
    color: #e4e4e7; /* Reset color inside block */
  }

  .docs-prose blockquote {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 2px solid var(--color-primary);
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.08) 0%, transparent 100%);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .docs-prose blockquote p {
    margin: 0;
    color: #d4d4d8;
  }
  
  .docs-prose blockquote strong {
    color: var(--color-primary);
  }

  .docs-prose table {
    width: 100%;
    margin-bottom: 2.5rem;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.01);
  }

  .docs-prose th, .docs-prose td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    text-align: left;
  }
  
  .docs-prose tr:last-child td {
    border-bottom: none;
  }

  .docs-prose th {
    background: rgba(255,255,255,0.03);
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
</style>
